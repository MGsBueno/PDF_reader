{
  "estruturas": {
    "blocos": {
      "Titulo": {
        "match": ["^titulo"],
        "fonte_minima": 12,
        "descricao_fonte_minima": 10
      },
      "Subtitulo": {
        "match": ["^subtitulo"],
        "fonte_minima": 12,
        "descricao_fonte_minima": 10
      },
      "Resumo": {
        "match": ["^resumo"],
        "fonte_minima": 12,
        "descricao_fonte_minima": 10
      },
      "Detalhes": {
        "match": ["^detalhes"],
        "fonte_minima": 12,
        "descricao_fonte_minima": 10
      }
    },
    "ignorar": [
      "Pagina",
      "Cabecalho",
      "Rodape"
    ],
    "nomes_blocos": [
      "Titulo",
      "Subtitulo",
      "Resumo",
      "Detalhes"
    ]
  }
}
