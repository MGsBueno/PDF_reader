{
  "structures": {
    "blocks": {
      "Title": {
        "match": [
          "^title"
        ],
        "minimum_font_size": 12,
        "minimum_description_font_size": 10
      },
      "Subtitle": {
        "match": [
          "^subtitle"
        ],
        "minimum_font_size": 12,
        "minimum_description_font_size": 10
      },
      "Summary": {
        "match": [
          "^summary"
        ],
        "minimum_font_size": 12,
        "minimum_description_font_size": 10
      },
      "Details": {
        "match": [
          "^details"
        ],
        "minimum_font_size": 12,
        "minimum_description_font_size": 10
      }
    },
    "ignore": [
      "Page",
      "Header",
      "Footer"
    ],
    "block_names": [
      "Title",
      "Subtitle",
      "Summary",
      "Details"
    ]
  }
}